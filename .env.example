# Autonomous Research Assistant — Environment Configuration
#
# Copy this file to .env and fill in any values you want to override.
# The application works entirely locally with no API keys required by default.

# Ollama model to use for the research agent.
# Make sure the model is pulled first: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# Maximum number of ReAct reasoning steps before the agent gives up.
AGENT_MAX_ITERATIONS=8

# ChromaDB persist directory (absolute or relative to project root).
# Leave blank to use the default: data/chroma_db
# CHROMA_PERSIST_DIR=

# Embedding model from HuggingFace (must be a sentence-transformers model).
# Leave blank to use the default: all-MiniLM-L6-v2
# EMBEDDING_MODEL=
